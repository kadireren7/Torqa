{
  "name": "torqa-desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "TORQA Desktop — native app for prompt-first builds, validated .tq specs, preview, and benchmarks. Requires the TORQA Python package (pip install -e .) on your machine.",
  "author": "TORQA contributors",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "test": "vitest run",
    "pack:win": "npm run build && electron-builder --win",
    "pack:win:dir": "npm run build && electron-builder --win --dir",
    "pack": "npm run build && electron-builder"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@uiw/codemirror-theme-vscode": "^4.23.6",
    "@uiw/react-codemirror": "^4.23.6",
    "codemirror": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "dev.torqa.desktop",
    "productName": "TORQA Desktop",
    "copyright": "Copyright © TORQA contributors",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
