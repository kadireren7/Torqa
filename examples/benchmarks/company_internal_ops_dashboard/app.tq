# Scope strip: region, team, fiscal period quick filters
# Primary grid: KPI variance vs comparison window
# Drilldown: entity-level exception queue and export job status
module benchmark.company_internal_ops_dashboard

intent ops_metrics_command_center
requires report_id, metric_key, time_range, dimension, drilldown_entity_id, comparison_window, export_job_id, anomaly_flag, password
result CommandCenterLoaded

flow:
