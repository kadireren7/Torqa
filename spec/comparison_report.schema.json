{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://torqa.dev/schema/comparison_report.schema.json",
  "title": "TORQA P136 comparison_report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "report_id",
    "generated_at",
    "honesty",
    "metric_catalog",
    "scenario_families",
    "family_coverage_counts",
    "source_reports",
    "flagship_reference",
    "token_proof_reference"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "report_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "documentation_md": { "type": "string" },
    "honesty": {
      "type": "object",
      "required": ["reference_en", "live_en"],
      "properties": {
        "reference_en": { "type": "string" },
        "live_en": { "type": "string" }
      }
    },
    "metric_catalog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "scope", "definition_en"],
        "properties": {
          "id": { "type": "string" },
          "scope": { "type": "string", "enum": ["reference", "live"] },
          "definition_en": { "type": "string" }
        }
      }
    },
    "scenario_families": { "type": "object" },
    "family_coverage_counts": { "type": "object" },
    "source_reports": { "type": "object" },
    "flagship_reference": { "type": "object" },
    "token_proof_reference": { "type": "object" }
  }
}
