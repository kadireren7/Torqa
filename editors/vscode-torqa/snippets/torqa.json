{
  "TORQA minimal shell": {
    "prefix": "tq-minimal",
    "body": [
      "intent ${1:demo_idle}",
      "requires ${2:username}, password",
      "result OK",
      "",
      "flow:",
      "$0"
    ],
    "description": "Minimal .tq: intent, requires, result, empty flow"
  },
  "TORQA login flow": {
    "prefix": "tq-login",
    "body": [
      "module ${1:auth.session}",
      "",
      "intent user_login",
      "requires username, password, ip_address",
      "forbid locked",
      "ensures session.created",
      "result ${2:Login completed}",
      "",
      "flow:",
      "  create session",
      "  emit login_success",
      "$0"
    ],
    "description": "Full login .tq: module, requires, forbid, ensures, result, flow steps"
  }
}
