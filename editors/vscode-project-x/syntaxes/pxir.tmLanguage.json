{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "pxir",
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.pxir",
          "match": "#.*$"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.pxir",
          "match": "\\b(?i)(goal|input|require|forbid|transition|result)\\b"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "name": "variable.other.pxir",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.pxir"
}
