{
  "name": "project-x-pxir",
  "displayName": "Project-X surface (.pxir)",
  "description": "Basic TextMate grammar for the line-oriented .pxir reference surface.",
  "version": "0.0.1",
  "publisher": "project-x",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "pxir",
        "aliases": ["Project-X surface", "pxir"],
        "extensions": [".pxir"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pxir",
        "scopeName": "source.pxir",
        "path": "./syntaxes/pxir.tmLanguage.json"
      }
    ]
  }
}
